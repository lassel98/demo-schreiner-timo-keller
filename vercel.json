{
  "rewrites": [
    {
      "source": "/",
      "destination": "/site/index.html"
    },
    {
      "source": "/css/(.*)",
      "destination": "/site/css/$1"
    },
    {
      "source": "/js/(.*)",
      "destination": "/site/js/$1"
    },
    {
      "source": "/img/(.*)",
      "destination": "/site/img/$1"
    }
  ]
}
